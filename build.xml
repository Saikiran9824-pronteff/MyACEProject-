<?xml version="1.0" encoding="UTF-8"?>
<project name="ace-ir-deploy" default="deploy" basedir=".">
    <!-- ================== PROPERTIES ================== -->
    <!-- Environment Variables -->
    <property environment="env"/>
    <!-- Timestamp -->
    <tstamp>
        <format property="DSTAMP" pattern="yyyyMMdd"/>
        <format property="TSTAMP" pattern="HHmmss"/>
    </tstamp>
    <!-- Repository Application Path -->
    <property name="BUILD_DIR" value="Applications"/>
    <!-- Jenkins Parameters -->
    <property name="APP_NAME" value="${APP_NAME}"/>
    <property name="IR_NAME" value="${IR_NAME}"/>
    <property name="NAMESPACE" value="${NAMESPACE}"/>
    <property name="BAR_TOOL" value="${BAR_TOOL}"/>
    <!-- Output -->
    <property name="OUTPUT_DIR" value="build"/>
    <property name="BAR_FILE"
              value="${OUTPUT_DIR}/${APP_NAME}.${DSTAMP}-${TSTAMP}.bar"/>
    <!-- ACE Tools -->
    <property name="ACE_TOOLS"
              value="/opt/ace-12.0.7.0/tools"/>
    <!-- GitHub Repository -->
    <property name="GITHUB_REPO"
              value="Saikiran9824-pronteff/MyACEProject-"/>
    <property name="GITHUB_BRANCH"
              value="main"/>
    <property name="GITHUB_PATH"
              value="bars/${APP_NAME}.${DSTAMP}-${TSTAMP}.bar"/>
    <property name="GIT_TOKEN"
              value="${env.GIT_TOKEN}"/>
    <!-- OpenShift -->
    <property name="OCP_URL"
              value="https://api.ocp.pronteff.com:6443"/>
    <property name="OCP_TOKEN"
              value="${env.OCP_TOKEN}"/>
    <!-- ================== CONDITIONS ================== -->
    <!-- ibmint -->
    <condition property="is.ibmint">
        <equals arg1="${BAR_TOOL}" arg2="ibmint"/>
    </condition>
    <!-- mqsicreatebar -->
    <condition property="is.mqsicreatebar">
        <equals arg1="${BAR_TOOL}" arg2="mqsicreatebar"/>
    </condition>
    <!-- ================== CLEAN ================== -->
    <target name="clean">
        <echo message="Cleaning old artifacts..."/>
        <delete dir="${OUTPUT_DIR}"/>
        <delete dir="workspace"/>
        <delete dir="repo"/>
    </target>
    <!-- ================== PREPARE WORKSPACE ================== -->
    <target name="prepare-workspace" depends="clean">
        <mkdir dir="workspace"/>
        <echo message="Copying ${APP_NAME} into workspace..."/>
        <copy todir="workspace/${APP_NAME}" failonerror="true">
            <fileset dir="${BUILD_DIR}/${APP_NAME}"/>
        </copy>
        <!-- Validate Eclipse Project -->
        <available file="workspace/${APP_NAME}/.project"
                   property="project.exists"/>
        <fail message=".project file not found in workspace/${APP_NAME}"
              unless="project.exists"/>
    </target>
    <!-- ================== CREATE BAR ================== -->
    <target name="create-bar">
        <mkdir dir="${OUTPUT_DIR}"/>
        <echo message="Creating BAR file for ${APP_NAME} using ${BAR_TOOL}"/>
    </target>
    <!-- ================== IBMINT BUILD ================== -->
    <target name="create-bar-ibmint"
            depends="create-bar"
            if="is.ibmint">
        <echo message="Using ibmint build..."/>
        <exec executable="ibmint" failonerror="true">
            <arg value="package"/>
            <arg value="--input-path"/>
            <arg value="${BUILD_DIR}/${APP_NAME}"/>
            <arg value="--output-bar-file"/>
            <arg value="${BAR_FILE}"/>
        </exec>
        <echo message="BAR Created: ${BAR_FILE}"/>
    </target>
    <!-- ================== MQSICREATEBAR BUILD ================== -->
    <target name="create-bar-mqsicreatebar"
            depends="prepare-workspace,create-bar"
            if="is.mqsicreatebar">
        <echo message="Using mqsicreatebar build..."/>
        <exec executable="${ACE_TOOLS}/mqsicreatebar"
              failonerror="true">
            <arg value="-data"/>
            <arg value="${basedir}/workspace"/>
            <arg value="-b"/>
            <arg value="${BAR_FILE}"/>
            <arg value="-a"/>
            <arg value="${APP_NAME}"/>
        </exec>
        <echo message="BAR Created: ${BAR_FILE}"/>
    </target>
    <!-- Wrapper -->
    <target name="create-bar-wrapper"
            depends="create-bar-ibmint,create-bar-mqsicreatebar"/>
    <!-- ================== LOGIN TO OPENSHIFT ================== -->
    <target name="oc-login">
        <echo message="Logging into OpenShift..."/>
        <exec executable="oc" failonerror="true">
            <arg value="login"/>
            <arg value="${OCP_URL}"/>
            <arg value="--token=${OCP_TOKEN}"/>
            <arg value="--insecure-skip-tls-verify=true"/>
        </exec>
        <exec executable="oc" failonerror="true">
            <arg value="project"/>
            <arg value="${NAMESPACE}"/>
        </exec>
    </target>
    <!-- ================== UPLOAD BAR TO GITHUB ================== -->
    <target name="upload-github"
            depends="create-bar-wrapper">
        <echo message="Uploading BAR to GitHub..."/>
        <!-- Cleanup -->
        <exec executable="bash" failonerror="false">
            <arg value="-c"/>
            <arg value="rm -rf repo"/>
        </exec>
        <!-- Git Config -->
        <exec executable="git" failonerror="true">
            <arg value="config"/>
            <arg value="--global"/>
            <arg value="user.email"/>
            <arg value="ci-bot@example.com"/>
        </exec>
        <exec executable="git" failonerror="true">
            <arg value="config"/>
            <arg value="--global"/>
            <arg value="user.name"/>
            <arg value="ci-bot"/>
        </exec>
        <!-- Clone Repository -->
        <exec executable="bash" failonerror="true">
            <arg value="-c"/>
            <arg value="git clone https://${GIT_TOKEN}@github.com/${GITHUB_REPO}.git repo"/>
        </exec>
        <!-- Ensure bars folder exists -->
        <mkdir dir="repo/bars"/>
        <!-- Copy BAR -->
        <exec executable="bash" failonerror="true">
            <arg value="-c"/>
            <arg value="cp ${BAR_FILE} repo/${GITHUB_PATH}"/>
        </exec>
        <!-- Commit and Push -->
        <exec executable="bash" failonerror="true">
            <arg value="-c"/>
            <arg value="cd repo &amp;&amp; git add ${GITHUB_PATH} &amp;&amp; git commit -m 'CI: Update BAR' &amp;&amp; git push origin ${GITHUB_BRANCH}"/>
        </exec>
    </target>
    <!-- ================== PATCH INTEGRATIONRUNTIME ================== -->
    <target name="patch-ir"
            depends="upload-github,oc-login">
        <property name="BAR_URL"
                  value="https://raw.githubusercontent.com/${GITHUB_REPO}/${GITHUB_BRANCH}/${GITHUB_PATH}"/>
        <echo message="Deploying BAR to IntegrationRuntime ${IR_NAME}"/>
        <exec executable="bash" failonerror="true">
            <arg value="-c"/>
            <arg value="oc patch integrationruntime ${IR_NAME} --type=merge -p '{&quot;spec&quot;:{&quot;barURL&quot;:[&quot;${BAR_URL}&quot;]}}' -n ${NAMESPACE}"/>
        </exec>
    </target>
    <!-- ================== VERIFY DEPLOYMENT ================== -->
    <target name="verify"
            depends="patch-ir">
        <echo message="Waiting for ACE pod rollout..."/>
        <exec executable="oc" failonerror="true">
            <arg value="wait"/>
            <arg value="--for=condition=Ready"/>
            <arg value="pod"/>
            <arg value="-l"/>
            <arg value="app.kubernetes.io/instance=${IR_NAME}"/>
            <arg value="--timeout=300s"/>
            <arg value="-n"/>
            <arg value="${NAMESPACE}"/>
        </exec>
        <echo message="BAR Deployment Completed Successfully"/>
    </target>
    <!-- ================== MAIN ================== -->
    <target name="deploy"
            depends="verify"/>
</project>
